{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["backbone_as", "igp", "ldp_enabled", "vrfs", "routers"],
  "properties": {
    "backbone_as": {
      "type": "integer",
      "minimum": 1
    },
    "igp": {
      "type": "string",
      "enum": ["OSPF"]
    },
    "ldp_enabled": {
      "type": "boolean"
    },
    "address_prefixes": {
      "type": "object",
      "properties": {
          "backbone": { "type": "string" },
          "loopback": { "type": "string" },
          "pe_ce": { "type": "string" }
      }
    },
    "vrfs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "rd": { "type": "string" },
          "rt": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "routers": {
      "type": "object",
      "required": ["P_ROUTERS", "PE_ROUTERS", "CE_ROUTERS"],
      "properties": {
        "P_ROUTERS": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["hostname", "interfaces"],
            "properties": {
              "hostname": { "type": "string" },
              "router_num": { "type": "integer", "minimum": 1 },
              "router_num_int": { "type": "integer", "minimum": 1 },
              "port": { "type": "integer" },
              "config_file_path": { "type": "string" },
              "interfaces": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name", "neighbor", "mpls"],
                  "properties": {
                    "name": { "type": "string" },
                    "neighbor_num": { "type": "integer", "minimum": 1 },
                    "neighbor": { "type": "string" },
                    "mpls": { "type": "boolean" }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false,
            "anyOf": [
              { "required": ["router_num"] },
              { "required": ["router_num_int"] }
            ]
          }
        },
        "PE_ROUTERS": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["hostname", "ibgp_to", "interfaces"],
            "properties": {
              "hostname": { "type": "string" },
              "router_num": { "type": "integer", "minimum": 1 },
              "router_num_int": { "type": "integer", "minimum": 1 },
              "port": { "type": "integer" },
              "config_file_path": { "type": "string" },
              "ibgp_to": { "type": "string" },
              "interfaces": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name"],
                  "properties": {
                    "name": { "type": "string" },
                    "neighbor_num": { "type": "integer", "minimum": 1 },
                    "neighbor_CE_num": { "type": "integer", "minimum": 1 },
                    "neighbor": { "type": "string" },
                    "mpls": { "type": "boolean" },
                    "vrf": { "type": "string" },
                    "desc": { "type": "string" },
                    "connected_to": { "type": "string" }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false,
            "anyOf": [
              { "required": ["router_num"] },
              { "required": ["router_num_int"] }
            ]
          }
        },
        "CE_ROUTERS": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["hostname", "as", "vrf", "connected_to"],
            "properties": {
              "hostname": { "type": "string" },
              "router_num": { "type": "integer", "minimum": 1 },
              "router_num_int": { "type": "integer", "minimum": 1 },
              "port": { "type": "integer" },
              "config_file_path": { "type": "string" },
              "as": {
                "type": "integer",
                "minimum": 1
              },
              "vrf": { "type": "string" },
              "interface": { "type": "string" },
              "connected_to": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}