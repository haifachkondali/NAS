{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "autonomous_systems": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "as_number": { "type": "integer" },
          "igp": { "type": "string" },
          "address_plan": {
            "type": "object",
            "properties": {
              "physical_base": { "type": "string" },
              "loopback_base": { "type": "string" }
            }
          },
          "neighbors": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "relationship": { "type": "string" },
                "bgp_type": { "type": "string" },
                "community_in": { "type": "string" }
              }
            }
          },
          "routers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "hostname": { "type": "string" },
                "id": { "type": "integer" },
                "console_port": { "type": "integer" },
                "interfaces": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": { "type": "string" },
                      "neighbor": { "type": "string" },
                      "remote_as": { "type": "integer" },
                      "ospf_cost": { "type": "integer" }
                    },
                    "required": ["name", "neighbor"]
                  }
                }
              },
              "required": ["hostname", "id", "interfaces", "console_port"]
            }
          }
        }
      }
    }
  }
}