{
  "backbone_as": 100,
  "igp": "OSPF",
  "ldp_enabled": true,

  "vrfs": [
    { "name": "CUST_A" },
    { "name": "CUST_B" }
  ],

  "routers": {
    "P_ROUTERS": [
      {
        "hostname": "P1",
        "port":5001,
        "router_num" : 2,
        "interfaces": [
          { "name": "GigabitEthernet1/0", "neighbor_num":1, "neighbor": "PE1", "mpls": true },
          { "name": "GigabitEthernet2/0", "neighbor_num":3, "neighbor": "P2", "mpls": true }
        ]
      },
      {
        "hostname": "P2",
        "config_file_path":"P2.cfg",
        "port":5002,
        "router_num" : 3,
        "interfaces": [
          { "name": "GigabitEthernet1/0", "neighbor_num":2, "neighbor": "PE2", "mpls": true },
          { "name": "GigabitEthernet2/0", "neighbor_num":4, "neighbor": "P1", "mpls": true }
        ]
      }
    ],

    "PE_ROUTERS": [
      {
        "hostname": "PE1",
        "port":5000,
        "ibgp_to": "PE2",
        "router_num" : 1,
        "interfaces": [
          { "name": "GigabitEthernet1/0", "neighbor_num":2, "neighbor": "P1", "mpls": true },
          { "name": "FastEthernet0/0", "neighbor_num":1, "vrf": "CUST_A", "connected_to": "CE1" },
          { "name": "GigabitEthernet2/0", "neighbor_num":3, "vrf": "CUST_B", "connected_to": "CE3" }
        ]
      },
      {
        "hostname": "PE2",
        "port":5003,
        "ibgp_to": "PE1",
        "router_num" : 4,
        "interfaces": [
          { "name": "GigabitEthernet1/0", "neighbor_num":2, "neighbor": "P2", "mpls": true },
          { "name": "FastEthernet0/0", "neighbor_CE_num":2, "vrf": "CUST_A", "connected_to": "CE2" },
          { "name": "GigabitEthernet2/0", "neighbor_CE_num":4, "vrf": "CUST_B", "connected_to": "CE4" }
        ]
      }
    ],

    "CE_ROUTERS": [
      { "hostname": "CE1", "port":5004, "as": 10, "vrf": "CUST_A", "connected_to": "PE1" },
      { "hostname": "CE2", "port":5006, "as": 10, "vrf": "CUST_A", "connected_to": "PE2" },
      { "hostname": "CE3", "port":5005, "as": 20, "vrf": "CUST_B", "connected_to": "PE1" },
      { "hostname": "CE4", "port":5007, "as": 20, "vrf": "CUST_B", "connected_to": "PE2" }
    ]
  }
}